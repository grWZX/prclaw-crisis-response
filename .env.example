# 复制本文件为 .env 后填写（不要提交 .env 到版本库）
# cp .env.example .env

# ---------- LLM（与 config/model.yaml 中 api_key_env 一致，默认 APIKEY）----------
APIKEY=

# 若使用 OpenAI 官方或其它兼容网关，可改用：
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---------- Neo4j（图谱 / GraphRAG）----------
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# ---------- 外部检索（可选）----------
# SERPER_API_KEY=

# ---------- Obsidian / Markdown 知识库（可选；与 config/unified_config.yaml 中 vault 配合）----------
# VAULT_PATH=./data/vault
